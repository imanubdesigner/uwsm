#!/bin/bash

# manu:summary=Songs details
# manu:group=
# manu:name=songs details
# manu:summary=Songs details
# manu:group=
# manu:name=songs details

if [[ $(playerctl -p spotify status 2>/dev/null) == "Playing" ]]; then
  status='  '
else
  status='  '
fi
song_info=$(playerctl -p spotify metadata --format "$status {{title}}      {{artist}}")
echo "$song_info"
