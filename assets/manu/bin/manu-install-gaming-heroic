#!/bin/bash

# manu:summary=Install Heroic Games Launcher (Epic, GOG, Amazon Prime Gaming) with graphics drivers.
# manu:requires-sudo=true

set -e

echo "Installing Heroic Games Launcher..."

manu-pkg-add heroic-games-launcher-bin
manu-install-gaming-gpu-lib32

setsid gtk-launch heroic >/dev/null 2>&1 &
