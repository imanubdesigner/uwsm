#!/bin/bash

# manu:summary=Shut down after closing application windows
# manu:examples=manu shutdown | manu system shutdown
# manu:aliases=manu shutdown

manu-state clear re*-required

# Schedule the shutdown to happen after closing windows (detached from terminal)
nohup bash -c "sleep 2 && systemctl poweroff --no-wall" >/dev/null 2>&1 &

# Now close all windows
manu-hyprland-window-close-all
sleep 1 # Allow apps like Chrome to shutdown correctly
