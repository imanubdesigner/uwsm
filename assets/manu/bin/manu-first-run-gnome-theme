#!/bin/bash

# Define the log path
LOG="$HOME/.local/share/manu/first-run.log"

echo "$(date): Starting GNOME theme and Matugen configuration..." >>"$LOG"

# Set GNOME interface themes
gsettings set org.gnome.desktop.interface gtk-theme 'adw-gtk3-dark' >>"$LOG" 2>&1
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark' >>"$LOG" 2>&1

sleep 0.5

AUTOSTART_FILE="$HOME/.config/hypr/modules/autostart.conf"

# Comment waypaper in the autostart file if it exists
if [ -f "$AUTOSTART_FILE" ]; then
  if sed -i 's|^exec-once = uwsm-app -- waypaper --restore|# exec-once = uwsm-app -- waypaper --restore|' "$AUTOSTART_FILE" >>"$LOG" 2>&1; then
    echo "$(date): Autostart file updated successfully." >>"$LOG"
  else
    echo "$(date): ERROR: Failed to update autostart file." >>"$LOG"
  fi
fi

echo "$(date): GNOME theme configuration finished." >>"$LOG"

# -------------------- Enable Themes --------------------

# Set links for Nautilus action icons
sudo ln -snf /usr/share/icons/Adwaita/symbolic/actions/go-previous-symbolic.svg /usr/share/icons/Yaru/scalable/actions/go-previous-symbolic.svg
sudo ln -snf /usr/share/icons/Adwaita/symbolic/actions/go-next-symbolic.svg /usr/share/icons/Yaru/scalable/actions/go-next-symbolic.svg

# Setup user theme folder
mkdir -p ~/.config/manu/themes

# Set initial theme
manu-theme-set "Tokyo Night"
rm -rf ~/.config/chromium/SingletonLock # otherwise archiso will own the chromium singleton

# Set specific app links for current theme
mkdir -p ~/.config/btop/themes
ln -snf ~/.config/manu/current/theme/btop.theme ~/.config/btop/themes/current.theme

mkdir -p ~/.config/mako
ln -snf ~/.config/manu/current/theme/mako.ini ~/.config/mako/config

# Add managed policy directories for Chromium and Brave for theme changes
sudo mkdir -p /etc/chromium/policies/managed
sudo chmod a+rw /etc/chromium/policies/managed

sudo mkdir -p /etc/brave/policies/managed
sudo chmod a+rw /etc/brave/policies/managed

# Default Chromium to follow system appearance ("device") instead of dark
echo '{"browser":{"theme":{"color_scheme":0}}}' | sudo tee /usr/lib/chromium/initial_preferences >/dev/null

# -------------------- Disable WiFi and Bluetooth at first boot --------------------
echo "$(date): Disabling WiFi and Bluetooth..." >>"$LOG"

rfkill block wifi >>"$LOG" 2>&1
rfkill block bluetooth >>"$LOG" 2>&1

echo "$(date): WiFi and Bluetooth disabled." >>"$LOG"


