#!/bin/bash

# --- Connectivity Check ---
# We use a loop to wait for an active internet connection.
# This prevents the pacman module from failing or showing 0 updates
# if the network interface (ethernet/iwd) takes a few seconds to initialize.

# Ping Cloudflare's DNS (1.1.1.1) as a lightweight connectivity test.
# -c 1: send only 1 packet
# -W 1: wait 1 second for a response
until ping -c 1 -W 1 1.1.1.1 >/dev/null 2>&1; do
  # Pause for 1 second before the next attempt to save CPU cycles
  sleep 1
done

# --- Execute Update Check ---
# Once the network is reachable, trigger the actual update check script.
manu-check-updates
