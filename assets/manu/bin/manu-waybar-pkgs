#!/bin/bash

# manu:summary=Waybar pkgs
# manu:group=
# manu:name=waybar pkgs

until ping -c 1 -W 1 1.1.1.1 >/dev/null 2>&1; do

  # Pause for 1 second before the next attempt to save CPU cycles
  sleep 1
done

# --- Execute Update Check ---
# Once the network is reachable, trigger the actual update check script.
manu-check-updates
