#!/bin/bash

# manu:summary=Finish the installation of Omarchy with items that can only be done after logging in.
# manu:requires-sudo=true

FLAG="$HOME/.local/share/manu/.first-run-done"
LOG="$HOME/.local/share/manu/first-run.log"

# Already ran — exit immediately
[[ -f "$FLAG" ]] && exit 0
mkdir -p "$(dirname "$LOG")"

# Silent execution, all output to log file
{
  echo "$(date): First run started"

  # -------------------- User-Dirs --------------------
  manu-first-run-user-dirs

  # -------------------- Firewall --------------------
  manu-first-run-firewall

  # -------------------- Elephant --------------------
  manu-first-run-elephant

  # -------------------- GNOME / GTK Theme --------------------
  manu-first-run-gnome-theme

  # -------------------- TUI Applications --------------------
  manu-first-run-tui

  # -------------------- Mise Configuration --------------------
  manu-first-run-mise

  # -------------------- NPX Wrapper Scripts --------------------
  manu-first-run-npx

  # -------------------- ZSH Configuration --------------------
  manu-first-run-zsh

  # -------------------- XDG user dirs --------------------
  xdg-user-dirs-update

  # -------------------- Snapper + Limine --------------------
  manu-first-run-limine-snapper

  # -------------------- Restore visudo --------------------
  manu-first-run-restore-visudo

  # Mark as done — won't run again
  touch "$FLAG"
  echo "$(date): First run completed successfully."
} >>"$LOG" 2>&1

# Desktop notification with nerd font checkmark
notify-send -t 5000 "First Run Script" "Configuration Complete  "
