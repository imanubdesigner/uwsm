#!/bin/bash

# manu:summary=Packages cleaning
# manu:group=
# manu:name=packages cleaning
# manu:summary=Packages cleaning
# manu:group=
# manu:name=packages cleaning

if ! command -v gum &>/dev/null; then
  echo "у°…–  Error: gum is required. Please install it (e.g., yay -S gum)."
  exit 1
fi

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# рџ”‘ Keep sudo active
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
check_sudo() {
  gum style \
    --margin="1 0" \
    "у°Ќ›  Checking sudo privileges..."

  # Check if sudo token exists or prompt for password
  if ! sudo -v &>/dev/null; then
    gum style \
      --bold \
      "у°…–  Failed to obtain sudo privileges. Exiting..."
    exit 1
  fi

  # Keep sudo token active in the background
  while true; do
    sudo -n true
    sleep 50
    kill -0 "$$" || exit
  done 2>/dev/null &
}

# Cleanup background jobs on exit
cleanup() { kill $(jobs -p) 2>/dev/null; }
trap cleanup EXIT

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# у°Ј– Display Header
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
show_header() {
  gum style \
    --border="rounded" \
    --padding="1 2" \
    --margin="1" \
    "у°Ј‡  Pacman & Yay Cache Cleaner" \
    "" \
    "   Clean package manager caches and free disk space"
}

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# у°Џ” Cache Size Utilities
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
get_cache_size_bytes() {
  local path=$1
  [ -d "$path" ] && du -sb "$path" 2>/dev/null | cut -f1 || echo "0"
}
bytes_to_human() {
  local bytes=$1
  if [ "$bytes" -eq 0 ]; then
    echo "0 B"
  else
    numfmt --to=iec-i --suffix=B "$bytes" 2>/dev/null || echo "${bytes} B"
  fi
}
check_cache_size() {
  local pacman_cache=$(du -sh /var/cache/pacman/pkg 2>/dev/null | cut -f1)
  local yay_cache=""
  [ -d "$HOME/.cache/yay" ] && yay_cache=$(du -sh "$HOME/.cache/yay" 2>/dev/null | cut -f1)
  gum style \
    --margin="1 0" \
    "у°Џ”  Current cache sizes:" \
    "   у°®Ї  Pacman:  $pacman_cache" \
    "   у°љ°  Yay:     ${yay_cache:-Not found}"
}

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# у°„¬  Pacman Cleaner
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
clean_pacman() {
  local option=$1
  local size_before=$(get_cache_size_bytes "/var/cache/pacman/pkg")
  local success=0

  # Check and remove Pacman lock file
  if [ -f /var/lib/pacman/db.lck ]; then
    gum style "у°Ћє  Found Pacman lock file (db.lck). Removing..."
    sudo rm /var/lib/pacman/db.lck
    gum style "у°Ћє  Lock file removed. Continuing cleanup."
  fi
  case $option in
  "Keep last 3 versions")
    gum spin --title "у°®Ї  Cleaning pacman cache (keep last 3 versions)..." -- sudo paccache -r
    success=$?
    ;;
  "Keep last version only")
    gum spin --title "у°®Ї  Cleaning pacman cache (keep last version)..." -- sudo paccache -rk1
    success=$?
    ;;
   "Remove all cached packages")
    if gum confirm --default=false "у°—Ў  Remove ALL cached pacman packages?"; then
      local pkg_count=$(find /var/cache/pacman/pkg -name "*.pkg.tar*" 2>/dev/null | wc -l)
      if [ "$pkg_count" -eq 0 ]; then
        gum style "   в†і  Cache already empty, nothing to remove"
        return
      fi
      gum style "у°®Ї  Removing all cached packages..."
      sudo pacman -Scc --noconfirm >/tmp/pacman_clean.log 2>&1
      success=$?
      sudo find /var/cache/pacman/pkg -type d -name "download-*" -exec rm -rf {} + 2>/dev/null
      local pkg_count_after=$(find /var/cache/pacman/pkg -name "*.pkg.tar*" 2>/dev/null | wc -l)
      if [ "$pkg_count_after" -eq 0 ]; then
        success=0
        gum style "у°®Ї  All cached packages removed successfully"
      else
        gum style "у°…™  Failed to clean cache completely. Check /tmp/pacman_clean.log"
      fi
    else
      gum style "   в†і  Skipped"
      return
    fi
    ;;
  esac
  if [ "$success" -eq 0 ]; then
    local size_after=$(get_cache_size_bytes "/var/cache/pacman/pkg")
    local freed=$((size_before - size_after))
    local freed_human=$(bytes_to_human $freed)
    gum style "у°„¬  Pacman cache cleaned successfully!"
    gum style --bold "   у°ЊЄ  Space freed: $freed_human"
  else
    gum style "у°…™  Error (Code $success) during Pacman cleanup."
  fi
  echo ""
}

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# у°љ°  Yay Cleaner
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
clean_yay() {
  if ! command -v yay &>/dev/null; then
    gum style "у°љЊ  Yay not installed. Skipping..."
    return
  fi
  local option=$1
  local size_before=$(get_cache_size_bytes "$HOME/.cache/yay")
  local success=0
  case $option in
   "Remove uninstalled packages")
    if gum confirm --default=false "у°—Ў  Remove uninstalled AUR packages cache?"; then
      gum style "у°љ°  Removing uninstalled packages cache..."
      yay -Sc --noconfirm 2>&1 | tee /tmp/yay_clean.log
      success=$?
    else
      gum style "   в†і  Skipped"
      return
    fi
    ;;
   "Remove all cached packages")
    if gum confirm --default=false "у°—Ў  Remove ALL AUR package cache?"; then
      gum style "у°љ°  Removing all packages cache..."
      yay -Scc --noconfirm >/tmp/yay_clean.log 2>&1
      success=$?
      if [ -d "$HOME/.cache/yay" ]; then
        find "$HOME/.cache/yay" -type d -name "download-*" -exec rm -rf {} + 2>/dev/null
      fi
      local remaining_pkgs=0
      if [ -d "$HOME/.cache/yay" ]; then
        remaining_pkgs=$(find "$HOME/.cache/yay" -name "*.pkg.tar*" 2>/dev/null | wc -l)
      fi
      if [ "$remaining_pkgs" -eq 0 ]; then
        success=0
        gum style "у°љ°  All cached packages removed successfully"
      else
        gum style "у°…™  Failed to clean cache completely. Check /tmp/yay_clean.log"
      fi
    else
      gum style "   в†і  Skipped"
      return
    fi
    ;;
  esac
  if [ "$success" -eq 0 ]; then
    local size_after=$(get_cache_size_bytes "$HOME/.cache/yay")
    local freed=$((size_before - size_after))
    local freed_human=$(bytes_to_human $freed)
    gum style "у°„¬  Yay cache cleaned successfully!"
    gum style --bold "   у°ЊЄ  Space freed: $freed_human"
  else
    gum style "у°…™  Error (Code $success) during Yay cleanup."
  fi
  echo ""
}

# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# у°Ј‡  Main Menu
# в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
main() {
  check_sudo
  show_header
  check_cache_size
  while true; do
    CLEAN_CHOICE=$(gum choose --header="у°Ј‡  What would you like to clean?" \
      "Pacman cache" \
      "Yay cache" \
      "Both" \
      "Exit")
    case $CLEAN_CHOICE in
    "Pacman cache")
      PACMAN_OPTION=$(gum choose --header="у°®Ї  Select cleaning method:" \
        "Keep last 3 versions" \
        "Keep last version only" \
        "Remove all cached packages")
      clean_pacman "$PACMAN_OPTION"
      ;;
    "Yay cache")
      YAY_OPTION=$(gum choose --header="у°љ°  Select cleaning method:" \
        "Remove uninstalled packages" \
        "Remove all cached packages")
      clean_yay "$YAY_OPTION"
      ;;
    "Both")
      PACMAN_OPTION=$(gum choose --header="у°®Ї  Pacman cleaning method:" \
        "Keep last 3 versions" \
        "Keep last version only" \
        "Remove all cached packages")
      clean_pacman "$PACMAN_OPTION"
      echo ""
      YAY_OPTION=$(gum choose --header="у°љ°  Yay cleaning method:" \
        "Remove uninstalled packages" \
        "Remove all cached packages")
      clean_yay "$YAY_OPTION"
      ;;
    "Exit")
      gum style "у°…–  Goodbye!"
      exit 0
      ;;
    esac
    check_cache_size
    echo ""
    gum confirm "у°„¬  Clean something else?" || break
  done
  gum style --bold "у°„›  All done! Stay frosty вќ„пёЏ"
}
main
