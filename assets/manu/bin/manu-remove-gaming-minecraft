#!/bin/bash

# manu:summary=Remove the Minecraft launcher along with its worlds, mods, and caches.
# manu:requires-sudo=true

set -e

manu-pkg-drop minecraft-launcher

rm -rf \
  "$HOME/.minecraft" \
  "$HOME/.config/Minecraft Launcher" \
  "$HOME/.local/share/minecraft-launcher" \
  "$HOME/.cache/minecraft"

echo ""
echo "Minecraft and its data have been removed."
