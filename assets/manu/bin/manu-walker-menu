#!/bin/bash

#    в”“ в”Ҹв”Ҹв”“в”“ в”“в”Ҹв”“в”Ҹв”“в”ів”“  в”ів”ів”“в”Ҹв”“в”ів”“в”ів”і
#    в”ғв”ғв”ғв”Јв”«в”ғ в”ғв”« в”Ј в”Јв”«  в”ғв”ғв”ғв”Ј в”ғв”ғв”ғв”ғ
#    в”—в”»в”ӣв”ӣв”—в”—в”ӣв”ӣв”—в”ӣв”—в”ӣв”ӣв”—  в”ӣ в”—в”—в”ӣв”ӣв”—в”—в”ӣ
#

export PATH="$HOME/.local/share/manu/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" |
    manu-launch-walker --dmenu --width 295 --minheight 1 --maxheight 600 -p "$promptвҖҰ" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.manu.terminal "$@"
}

present_terminal() {
  manu-launch-floating-terminal-with-presentation $1
}

install() {
  present_terminal "echo 'Installing $1...'; manu-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; manu-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; manu-pkg-add $2 && sleep 2 && manu-font-set '$3'"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; manu-pkg-aur-add $2"
}

open_in_editor() {
  notify-send "Editing config file" "$1"
  manu-launch-editor "$1"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; manu-pkg-aur-add $2 && setsid gtk-launch $3"
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_capture_menu() {
  case $(menu "Capture" "пҖ°  Screenshot\nпҖҪ  Screenrecord\nу°ғү  Color") in
  *Screenshot*)
    manu-cmd-screenshot
    ;;
  *Screenrecord*)
    show_screenrecord_menu
    ;;
  *Color*)
    pkill hyprpicker || hyprpicker -a
    ;;
  *)
    back_to show_trigger_menu
    ;;
  esac
}

show_screenrecord_menu() {
  manu-cmd-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "пҖҪ  With no audio\nпҖҪ  With desktop audio\nпҖҪ  With desktop + microphone audio\nпҖҪ  With desktop + microphone audio + webcam") in
  *"With no audio")
    manu-cmd-screenrecord
    ;;
  *"With desktop audio")
    manu-cmd-screenrecord --with-desktop-audio
    ;;
  *"With desktop + microphone audio")
    manu-cmd-screenrecord --with-desktop-audio --with-microphone-audio
    ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    manu-cmd-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *)
    back_to show_capture_menu
    ;;
  esac
}

show_learn_menu() {
  case $(menu "Learn" "оүө  Hyprland\nпҢғ  Arch\nо ә  Neovim\nоҜҠ  Bash\nуұЈ»  Gowall\nу°ҮҘ  Yazi\nу°ҢҢ  Keybindings") in
  *Hyprland*) manu-launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) manu-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) manu-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) manu-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *Gowall*) manu-launch-webapp "https://achno.github.io/gowall-docs/" ;;
  *Yazi*) manu-launch-webapp "https://yazi-rs.github.io/docs/quick-start/" ;;
  *Keybindings*) manu-menu-keybindings ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "пҖ°  Capture\nп”Һ  Share\nу°Ёҡ  Toggle") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "пҒҝ  Clipboard\nо©»  File \nп„”  Folder") in
  *Clipboard*) terminal bash -c "manu-cmd-share clipboard" ;;
  *File*) terminal bash -c "manu-cmd-share file" ;;
  *Folder*) terminal bash -c "manu-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "уұ„„  Screensaver\nоҚҢ  Nightlight\nуұ«–  Idle Lock\nу°–Ҝ  Top Bar\nу°ө…  Power Profile\nуұӮ¬  Workspace Layout\nоҳӘ  Window Gaps\nпӢҗ  1-Window Ratio\nу°Қ№  Display Scaling") in
  *Screensaver*) manu-toggle-screensaver ;;
  *Nightlight*) manu-toggle-night ;;
  *Idle*) manu-toggle-idle ;;
  *Bar*) manu-toggle-waybar ;;
  *"Power Profile"*) show_power_profile_menu ;;
  *Layout*) manu-hyprland-workspace-layout-toggle ;;
  *Ratio*) manu-hyprland-window-single-square-aspect-toggle ;;
  *Gaps*) manu-hyprland-window-gaps-toggle ;;
  *Scaling*) manu-hyprland-monitor-scaling-cycle ;;
  *) show_trigger_menu ;;
  esac
}

show_power_profile_menu() {
  local profile
  profile=$(menu "Power Profile" "$(manu-powerprofiles-list)")
  if [[ -z "$profile" ]]; then
    back_to show_toggle_menu
  else
    manu-powerprofiles-set "$profile"
  fi
}

show_style_menu() {
  case $(menu "Style" "у°ёҢ  Theme\nу°ү”  Background\nоҷҷ  Font\nпҚҷ  Hyprland\nуұ„„  Screensaver") in
  *Theme*) show_theme_menu ;;
  *Background*) show_background_menu ;;
  *Font*) show_font_menu ;;
  *Hyprland*) open_in_editor ~/.config/hypr/modules/decorations.conf ;;
  *Screensaver*) open_in_editor ~/.local/share/manu/screensaver.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  manu-launch-walker -m menus:manuthemes --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(manu-font-list)" "--width 350" "$(manu-font-current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    manu-font-set "$theme"
  fi
}

show_background_menu() {
  manu-launch-walker -m menus:manuBackgroundSelector --width 800 --minheight 400
}

show_install_menu() {
  case $(menu "Install" "у°ЈҮ  Package\nу°Ӯ“  AUR\nу°Ҡў  Git Configuration\nу°–ҹ  Web App\nу°һ·  TUI\nоҜҸ  Style\nоҹ°  Chromium") in
  *Package*) terminal manu-pkg-install ;;
  *AUR*) terminal manu-pkg-aur-install ;;
  *Git*) present_terminal manu-install-git-configuration ;; # Nuovo comando
  *AUR*) terminal manu-pkg-aur-install ;;
  *Web*) present_terminal manu-install-webapp ;;
  *TUI*) present_terminal manu-install-tui ;;
  *Style*) show_install_style_menu ;;
  *Chromium*) present_terminal manu-install-chromium-google-account ;;
  *) show_main_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "у°ёҢ  Theme\nпҖҫ  Background\nоҷҷ  Font") in
  *Theme*) present_terminal manu-theme-install ;;
  *Background*) manu-theme-bg-install ;;
  *Font*) show_install_font_menu ;;
  *) show_install_menu ;;
  esac
}

show_install_font_menu() {
  case $(menu "Install" "оҷҷ  Cascadia Mono\nоҷҷ  Meslo LG Mono\nоҷҷ  Fira Code\nоҷҷ  Victor Code\nоҷҷ  Bistream Vera Mono\nоҷҷ  Iosevka" "--width 350") in
  *Cascadia*) install_font "Cascadia Mono" "ttf-cascadia-mono-nerd" "CaskaydiaMono Nerd Font" ;;
  *Meslo*) install_font "Meslo LG Mono" "ttf-meslo-nerd" "MesloLGL Nerd Font" ;;
  *Fira*) install_font "Fira Code" "ttf-firacode-nerd" "FiraCode Nerd Font" ;;
  *Victor*) install_font "Victor Code" "ttf-victor-mono-nerd" "VictorMono Nerd Font" ;;
  *Bistream*) install_font "Bistream Vera Code" "ttf-bitstream-vera-mono-nerd" "BitstromWera Nerd Font" ;;
  *Iosevka*) install_font "Iosevka" "ttf-iosevka-nerd" "Iosevka Nerd Font Mono" ;;
  *) show_install_menu ;;
  esac
}

show_remove_menu() {
  case $(menu "Remove" "у°ЈҮ  Package\nоқғ  Web App\nоӘ…  TUI\nу°®Ҝ  Cache Packages\nп…ң  Clear Logs\nу°ёҢ  Theme") in
  *Cache*) present_terminal manu-packages-cleaning ;;
  *Package*) terminal manu-pkg-remove ;;
  *Web*) present_terminal manu-webapp-remove ;;
  *TUI*) present_terminal manu-tui-remove ;;
  *"Clear Logs"*) present_terminal manu-clear-journalctl ;;
  *Theme*) present_terminal manu-theme-remove ;;
  *) show_main_menu ;;
  esac
}

show_update_menu() {
  case $(menu "Update" "у°ЈҮ  Pacman\nо©ё  Firmware\nу°ёҢ  Extra Themes\nо¬Ғ  Timezone\nоҺғ  Time") in
  *Pacman*) present_terminal manu-update ;;
  *Firmware*) present_terminal manu-update-firmware ;;
  *Themes*) present_terminal manu-theme-update ;;
  *Timezone*) present_terminal manu-tz-select ;;
  *Time*) present_terminal manu-update-time ;;
  *) show_main_menu ;;
  esac
}

show_restart_menu() {
  case $(menu "Restart" "у°„„  Apps\nу°ҳ“  Hardware") in
  *Apps*) show_restart_apps_menu ;;
  *Hardware*) show_restart_hardware_menu ;;
  *) show_main_menu ;;
  esac
}

show_restart_apps_menu() {
  case $(menu "Restart Apps" "у°Ў—  Sudo\nуұ“һ  Walker\nпғү  Waybar\nпҚқ  Swayosd\nуұ«–  Hypridle\nпғ«  Hyprsunset\nу°һ…  XCompose") in
  *Sudo*) present_terminal manu-reset-sudo ;;
  *Walker*) manu-restart-walker ;;
  *Waybar*) manu-restart-waybar ;;
  *Swayosd*) manu-restart-swayosd ;;
  *Hypridle*) manu-restart-hypridle ;;
  *Hyprsunset*) manu-restart-hyprsunset ;;
  *XCompose*) manu-restart-xcompose ;;
  *) show_restart_menu ;;
  esac
}

show_restart_hardware_menu() {
  case $(menu "Restart Hardware" "  оҳё  Audio\n  уұҡҫ  Wi-Fi\n  у°ӮҜ  Bluetooth") in
  *Audio*) present_terminal manu-restart-pipewire ;;
  *Wi-Fi*) present_terminal manu-restart-wifi ;;
  *Bluetooth*) present_terminal manu-restart-bluetooth ;;
  *) show_restart_menu ;;
  esac
}

show_tools_menu() {
  case $(menu "Tools" "у°ҒҜ  Snapper Backup\nу°Ҹ”  Pkg History\nу°Ұ—  Media Downloader\nуұҠһ  ISO to USB\nу°ЈҢ  Image Converter\nпҖҪ  Video Converter") in
  *"Snapper Backup"*) present_terminal manu-snapper-backup ;;
  *"Pkg History"*) present_terminal manu-pkg-history ;;
  *"Media Downloader"*) present_terminal manu-media-download ;;
  *"ISO to USB"*) present_terminal manu-write-iso ;;
  *"Image Converter"*) present_terminal manu-transcode-image ;;
  *"Video Converter"*) present_terminal manu-transcode-video ;;
  *) show_main_menu ;;
  esac
}

show_system_menu() {
  case $(menu "System" "у°Ңҫ  Lock\nуұ„„  Screensaver\nу°ңү  Restart\nпҖ‘  Shutdown") in
  *Lock*) manu-lock-screen ;;
  *Screensaver*) manu-launch-screensaver force ;;
  *Restart*) manu-system-reboot ;;
  *Shutdown*) manu-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_about() {
  manu-launch-about
}

show_main_menu() {
  go_to_menu "$(menu "у°•°  Go" "у°өҶ  App\nоӘӨ  Learn\nпғ§  Trigger\nоҜҸ  Style\nо¬©  Install\nпҮё  Remove\nу°ҡ°  Update\nо«’  Restart\nоҲҸ  Tools\nу°ӢҪ  About\nпҖ‘  System")"
}

go_to_menu() {
  case "${1,,}" in
  *app*) walker -p "LaunchвҖҰ" ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *keybindings*) manu-menu-keybindings ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *share*) show_share_menu ;;
  *power*) show_power_profile_menu ;;
  *background*) show_background_menu ;;
  *capture*) show_capture_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *restart*) show_restart_menu ;;
  *tools*) show_tools_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi
