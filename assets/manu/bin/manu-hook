#!/bin/bash

# manu:summary=Run a named hook, like post-update (available in ~/.config/manu/hooks/post-update).
# manu:args=[name] [args...]

set -e
if [[ $# -lt 1 ]]; then
  echo "Usage: manu-hook [name] [args...]"
  exit 1
fi
HOOK=$1
HOOK_PATH="$HOME/.config/manu/hooks/$1"
shift
if [[ -f $HOOK_PATH ]]; then
  bash "$HOOK_PATH" "$@"
fi
