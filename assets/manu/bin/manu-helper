#!/bin/bash

# manu:summary=Helper
# manu:group=
# manu:name=helper
# manu:summary=Helper
# manu:group=
# manu:name=helper

_NC='\033[0m'

# --- Nerd Font icons (minimal, no emoji)
_ICON_STEP=""
_ICON_INFO=""
_ICON_SUCCESS=""
_ICON_ERROR=""
_ICON_ARROW=""
_ICON_SPIN=""

# --- Check if gum exists
_has_gum() {
  command -v gum &>/dev/null
}
is_installed() {
  pacman -Q "$1" &>/dev/null
}
ensure_gum() {
  if ! is_installed "gum"; then
    echo "Installing gum for better UI..."
    sudo pacman -S --noconfirm gum
  fi
}

# --- HEADER
log_header() {
  local text="$1"
  if _has_gum; then
    echo
    gum style \
      --border double \
      --padding "0 2" \
      --margin "1 0" \
      --width 50 \
      --align center \
      "$text"
    echo
  else
    echo -e "\n════════════════════════════════════════"
    echo -e "  $text"
    echo -e "════════════════════════════════════════\n"
  fi
}

# --- STEP
log_step() {
  local text="$1"
  if _has_gum; then
    gum style --bold "$_ICON_STEP $text"
  else
    echo -e "$_ICON_STEP $text"
  fi
}

# --- INFO
log_info() {
  local text="$1"
  if _has_gum; then
    gum style "  $_ICON_INFO $text"
  else
    echo -e "  $_ICON_INFO $text"
  fi
}

# --- SUCCESS
log_success() {
  local text="$1"
  if _has_gum; then
    gum style "  $_ICON_SUCCESS $text"
  else
    echo -e "  $_ICON_SUCCESS $text"
  fi
}

# --- ERROR
log_error() {
  local text="$1"
  if _has_gum; then
    gum style --bold "  $_ICON_ERROR $text"
  else
    echo -e "  $_ICON_ERROR $text"
  fi
}

# --- DETAIL
log_detail() {
  local text="$1"
  if _has_gum; then
    gum style "    $_ICON_ARROW $text"
  else
    echo -e "    $_ICON_ARROW $text"
  fi
}

# --- SPINNER
spinner() {
  local title="$1"
  shift
  if _has_gum; then
    gum spin --spinner dot --title "$title" --show-error -- "$@"
  else
    echo -e "$_ICON_SPIN $title"
    "$@"
  fi
}

# --- ASK YES/NO
ask_yes_no() {
  local prompt="$1"
  if _has_gum; then
    gum confirm "$prompt" && return 0 || return 1
  else
    while true; do
      read -p "$prompt [y/n]: " yn
      case $yn in
      [Yy]*) return 0 ;;
      [Nn]*) return 1 ;;
      *) echo "Please answer yes or no." ;;
      esac
    done
  fi
}

# --- PROGRESS
log_progress() {
  local text="$1"
  local count="$2"
  if _has_gum; then
    gum style "  [$count] $text"
  else
    echo -e "  [$count] $text"
  fi
}

# --- HARDWARE DETECTION
detect_hardware_type() {
  if ls /sys/class/power_supply/BAT* >/dev/null 2>&1 || [ -d /sys/class/power_supply/battery ]; then
    echo "laptop"
  else
    echo "desktop"
  fi
}
has_nvidia_gpu() {
  lspci | grep -i nvidia &>/dev/null
}
remove_path() {
  local target="$1"
  if [ -L "$target" ] && [ ! -e "$target" ]; then
    rm -f "$target"
  elif [ -e "$target" ]; then
    rm -rf "$target"
  fi
}
