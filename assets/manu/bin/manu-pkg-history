#!/bin/zsh

# manu:summary=Pkg history
# manu:group=
# manu:name=pkg history

fetch_events() {
    local limit=$1
    grep -E "installed|upgraded|removed" /var/log/pacman.log |
    tail -n "$limit" | while read -r line; do
        date_time=$(echo "$line" | awk '{print $1, $2}' | tr -d '[]')
        action=$(echo "$line" | awk '{print $3}')
        package=$(echo "$line" | cut -d' ' -f4-)
        case "$action" in
            installed)
                icon="пЃ§"
                ;;
            upgraded)
                icon="п‚©"
                ;;
            removed)
                icon="пЃЁ"
                ;;
            *)
                icon="пЃ±"
                ;;
        esac

        # Stile neutro senza colori forzati
        gum style "$date_time $icon $package"
    done
}

# в”Ђв”Ђ Title box в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
gum style \
  --border normal \
  --bold \
  --align center \
  --width 60 \
  "пЊѓ  Recent Pacman Package Events"

# в”Ђв”Ђ Legend в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
gum style --align center --width 60 <<EOF
$(gum style "пЃ§ installed")   \
$(gum style "п‚© upgraded")   \
$(gum style "пЃЁ removed")
EOF

# в”Ђв”Ђ Menu в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
choice=$(gum choose \
  "у°€™  Show last 10 events" \
  "у°€љ  Show last 20 events" \
  "у°†Ќ  Show last 50 events" \
  "пЃ—  Exit")
case "$choice" in
    "у°€™  Show last 10 events") limit=10 ;;
    "у°€љ  Show last 20 events") limit=20 ;;
    "у°†Ќ  Show last 50 events") limit=50 ;;
    "пЃ—  Exit") exit 0 ;;
    *) exit 0 ;;
esac

# в”Ђв”Ђ Output в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
fetch_events "$limit"
