#!/bin/bash

if [[ -z $1 ]]; then
  echo "Usage: manu-theme-set <theme-name>"
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/manu/current/theme"
NEXT_THEME_PATH="$HOME/.config/manu/current/next-theme"
USER_THEMES_PATH="$HOME/.config/manu/themes"
MANU_THEMES_PATH="$MANU_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')

if [[ ! -d $MANU_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$MANU_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate colors.toml from alacritty.toml if theme is missing colors.toml
if [[ ! -f $NEXT_THEME_PATH/colors.toml && -f $NEXT_THEME_PATH/alacritty.toml ]]; then
  manu-theme-colors-from-alacritty "$NEXT_THEME_PATH"
fi

# Generate dynamic configs
manu-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Link neovim theme as lazy plugin so lazy detects config change and hot-reloads
ln -sf "$HOME/.config/manu/current/theme/neovim.lua" "$HOME/.config/nvim/lua/plugins/theme.lua"

# Store theme name for reference
echo "$THEME_NAME" >"$HOME/.config/manu/current/theme.name"

# Change background with theme
manu-theme-bg-next

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  manu-restart-waybar
fi
manu-restart-swayosd
manu-restart-terminal
manu-restart-hyprctl
manu-restart-btop
manu-restart-opencode
manu-restart-mako

# Change app-specific themes
manu-theme-set-gnome
manu-theme-set-browser
manu-theme-set-vscode
manu-theme-set-obsidian

# Call hook on theme set
manu-hook theme-set "$THEME_NAME"
