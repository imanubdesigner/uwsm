#!/bin/bash

# manu:summary=Set the power profile to the requested level, falling back to balanced
# manu:args=<ac|battery>

notify() {
  local icon="$1"
  local message="$2"
  notify-send -h string:x-canonical-private-synchronous:powerprofile \
    "$icon  Power Profile" "$message"
}
mapfile -t profiles < <(powerprofilesctl list | awk '/^\s*[* ]\s*[a-zA-Z0-9\-]+:$/ { gsub(/^[*[:space:]]+|:$/,""); print }')
case "$1" in
ac)
  if [[ " ${profiles[*]} " == *" performance "* ]]; then
    sudo powerprofilesctl set performance
    notify "󱐋" "Switched to Performance mode"
  else
    sudo powerprofilesctl set balanced
    notify "󰾆" "Performance unavailable → using Balanced"
  fi
  ;;
battery)
  sudo powerprofilesctl set balanced
  notify "󰾆" "Switched to Balanced mode (battery)"
  ;;
*)
  if [[ -n "$1" ]]; then
    sudo powerprofilesctl set "$1"
    case "$1" in
    performance)
      notify "󱐋" "Performance mode enabled"
      ;;
    balanced)
      notify "󰾆" "Balanced mode enabled"
      ;;
    power-saver)
      notify "󰁹" "Power Saver enabled"
      ;;
    *)
      notify "󰁜" "Profile set to: $1"
      ;;
    esac
  fi
  ;;
esac
