  *Python*) present_terminal "manu-remove-dev-env python" ;;
  *Elixir*) show_remove_elixir_menu ;;
  *Zig*) present_terminal "manu-remove-dev-env zig" ;;
  *Rust*) present_terminal "manu-remove-dev-env rust" ;;
  *Java*) present_terminal "manu-remove-dev-env java" ;;
  *NET*) present_terminal "manu-remove-dev-env dotnet" ;;
  *OCaml*) present_terminal "manu-remove-dev-env ocaml" ;;
  *Clojure*) present_terminal "manu-remove-dev-env clojure" ;;
