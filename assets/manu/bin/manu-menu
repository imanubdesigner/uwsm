#!/bin/bash

#    ┓ ┏┏┓┓ ┓┏┓┏┓┳┓  ┳┳┓┏┓┳┓┳┳
#    ┃┃┃┣┫┃ ┃┫ ┣ ┣┫  ┃┃┃┣ ┃┃┃┃
#    ┗┻┛┛┗┗┛┛┗┛┗┛┛┗  ┛ ┗┗┛┛┗┗┛
#

export PATH="$HOME/.local/share/manu/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" |
    manu-launch-walker --dmenu --width 295 --minheight 1 --maxheight 600 -p "$prompt…" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec --app-id=org.manu.terminal "$@"
}

present_terminal() {
  manu-launch-floating-terminal-with-presentation $1
}

install() {
  present_terminal "echo 'Installing $1...'; manu-pkg-add $2"
}

install_and_launch() {
  present_terminal "echo 'Installing $1...'; manu-pkg-add $2 && setsid gtk-launch $3"
}

install_font() {
  present_terminal "echo 'Installing $1...'; manu-pkg-add $2 && sleep 2 && manu-font-set '$3'"
}

aur_install() {
  present_terminal "echo 'Installing $1 from AUR...'; manu-pkg-aur-add $2"
}

open_in_editor() {
  notify-send "Editing config file" "$1"
  manu-launch-editor "$1"
}

aur_install_and_launch() {
  present_terminal "echo 'Installing $1 from AUR...'; manu-pkg-aur-add $2 && setsid gtk-launch $3"
}

get_webcam_list() {
  v4l2-ctl --list-devices 2>/dev/null | while IFS= read -r line; do
    if [[ $line != $'\t'* && -n $line ]]; then
      local name="$line"
      IFS= read -r device || break
      device=$(echo "$device" | tr -d '\t' | head -1)
      [[ -n $device ]] && echo "$device  $name"
    fi
  done
}

show_webcam_select_menu() {
  local devices=$(get_webcam_list)
  local count=$(echo "$devices" | grep -c . 2>/dev/null || echo 0)

  if [[ -z $devices ]] || ((count == 0)); then
    notify-send "No webcam devices found" -u critical -t 3000
    return 1
  fi

  if ((count == 1)); then
    echo "$devices" | awk '{print $1}'
  else
    menu "Select Webcam" "$devices" | awk '{print $1}'
  fi
}

show_capture_menu() {
  case $(menu "Capture" "  Screenshot\n  Screenrecord\n󰃉  Color") in
  *Screenshot*)
    manu-capture-screenshot
    ;;
  *Screenrecord*)
    show_screenrecord_menu
    ;;
  *Color*)
    pkill hyprpicker || hyprpicker -a
    ;;
  *)
    back_to show_trigger_menu
    ;;
  esac
}

show_screenrecord_menu() {
  manu-capture-screenrecord --stop-recording && exit 0

  case $(menu "Screenrecord" "  With no audio\n  With desktop audio\n  With desktop + microphone audio\n  With desktop + microphone audio + webcam") in
  *"With no audio")
    manu-capture-screenrecord
    ;;
  *"With desktop audio")
    manu-capture-screenrecord --with-desktop-audio
    ;;
  *"With desktop + microphone audio")
    manu-capture-screenrecord --with-desktop-audio --with-microphone-audio
    ;;
  *"With desktop + microphone audio + webcam")
    local device=$(show_webcam_select_menu) || {
      back_to show_capture_menu
      return
    }
    manu-capture-screenrecord --with-desktop-audio --with-microphone-audio --with-webcam --webcam-device="$device"
    ;;
  *)
    back_to show_capture_menu
    ;;
  esac
}

show_learn_menu() {
  case $(menu "Learn" "  Hyprland\n  Arch\n  Neovim\n  Bash\n󱣻  Gowall\n󰇥  Yazi\n󰌌  Keybindings") in
  *Hyprland*) manu-launch-webapp "https://wiki.hypr.land/" ;;
  *Arch*) manu-launch-webapp "https://wiki.archlinux.org/title/Main_page" ;;
  *Bash*) manu-launch-webapp "https://devhints.io/bash" ;;
  *Neovim*) manu-launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *Gowall*) manu-launch-webapp "https://achno.github.io/gowall-docs/" ;;
  *Yazi*) manu-launch-webapp "https://yazi-rs.github.io/docs/quick-start/" ;;
  *Keybindings*) manu-menu-keybindings ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "  Capture\n  Share\n󰨚  Toggle") in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "  Clipboard\n  File \n  Folder") in
  *Clipboard*) terminal bash -c "manu-menu-share clipboard" ;;
  *File*) terminal bash -c "manu-menu-share file" ;;
  *Folder*) terminal bash -c "manu-menu-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "󱄄  Screensaver\n  Nightlight\n󱫖  Idle Lock\n󰖯  Top Bar\n󰵅  Power Profile\n󱂬  Workspace Layout\n  Window Gaps\n  1-Window Ratio\n󰍹  Display Scaling\n󰟵  Sudo Passwordless") in
  *Screensaver*) manu-toggle-screensaver ;;
  *Nightlight*) manu-toggle-night ;;
  *Idle*) manu-toggle-idle ;;
  *Bar*) manu-toggle-waybar ;;
  *"Power Profile"*) show_power_profile_menu ;;
  *Layout*) manu-hyprland-workspace-layout-toggle ;;
  *Ratio*) manu-hyprland-window-single-square-aspect-toggle ;;
  *Gaps*) manu-hyprland-window-gaps-toggle ;;
  *Scaling*) manu-hyprland-monitor-scaling-cycle ;;
  *"Sudo Passwordless"*) present_terminal manu-sudo-passwordless ;;
  *) show_trigger_menu ;;
  esac
}

show_power_profile_menu() {
  local profile
  profile=$(menu "Power Profile" "$(manu-powerprofiles-list)")
  if [[ -z "$profile" ]]; then
    back_to show_toggle_menu
  else
    manu-powerprofiles-set "$profile"
  fi
}

show_style_menu() {
  case $(menu "Style" "󰸌  Theme\n󰉔  Background\n  Font\n  Hyprland\n󱄄  Screensaver") in
  *Theme*) show_theme_menu ;;
  *Background*) show_background_menu ;;
  *Font*) show_font_menu ;;
  *Hyprland*) open_in_editor ~/.config/hypr/modules/decorations.conf ;;
  *Screensaver*) open_in_editor ~/.local/share/manu/screensaver.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  manu-launch-walker -m menus:manuthemes --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(manu-font-list)" "--width 350" "$(manu-font-current)")
  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    manu-font-set "$theme"
  fi
}

show_background_menu() {
  manu-launch-walker -m menus:manuBackgroundSelector --width 800 --minheight 400
}

show_install_menu() {
  case $(menu "Install" "󰣇  Package\n󰂓  AUR\n󰊢  Git Configuration\n󰖟  Web App\n󰞷  TUI\n󰵮  Development\n  Style\n  Chromium") in
  *Package*) terminal manu-pkg-install ;;
  *AUR*) terminal manu-pkg-aur-install ;;
  *Git*) present_terminal manu-install-git-configuration ;; # Nuovo comando
  *AUR*) terminal manu-pkg-aur-install ;;
  *Web*) present_terminal manu-install-webapp ;;
  *TUI*) present_terminal manu-install-tui ;;
  *Development*) show_install_development_menu ;;
  *Style*) show_install_style_menu ;;
  *Chromium*) present_terminal manu-install-chromium-google-account ;;
  *) show_main_menu ;;
  esac
}

