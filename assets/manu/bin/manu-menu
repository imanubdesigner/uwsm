  case $(menu "Install" "󰸌  Theme\n  Background\n  Font") in
  *Theme*) present_terminal manu-theme-install ;;
  *Background*) manu-theme-bg-install ;;
  *Font*) show_install_font_menu ;;
  *) show_install_menu ;;
  esac
}

show_install_font_menu() {
  case $(menu "Install" "  Cascadia Mono\n  Meslo LG Mono\n  Fira Code\n  Victor Code\n  Bistream Vera Mono\n  Iosevka" "--width 350") in
  *Cascadia*) install_font "Cascadia Mono" "ttf-cascadia-mono-nerd" "CaskaydiaMono Nerd Font" ;;
  *Meslo*) install_font "Meslo LG Mono" "ttf-meslo-nerd" "MesloLGL Nerd Font" ;;
  *Fira*) install_font "Fira Code" "ttf-firacode-nerd" "FiraCode Nerd Font" ;;
  *Victor*) install_font "Victor Code" "ttf-victor-mono-nerd" "VictorMono Nerd Font" ;;
  *Bistream*) install_font "Bistream Vera Code" "ttf-bitstream-vera-mono-nerd" "BitstromWera Nerd Font" ;;
  *Iosevka*) install_font "Iosevka" "ttf-iosevka-nerd" "Iosevka Nerd Font Mono" ;;
  *) show_install_menu ;;
  esac
}

show_remove_menu() {
  case $(menu "Remove" "󰣇  Package\n  Web App\n  TUI\n󰵮  Development\n󰮯  Cache Packages\n  Clear Logs\n󰸌  Theme") in
  *Cache*) present_terminal manu-packages-cleaning ;;
  *Package*) terminal manu-pkg-remove ;;
  *Web*) present_terminal manu-webapp-remove ;;
  *TUI*) present_terminal manu-tui-remove ;;
  *Development*) show_remove_development_menu ;;
  *"Clear Logs"*) present_terminal manu-clear-journalctl ;;
  *Theme*) present_terminal manu-theme-remove ;;
  *) show_main_menu ;;
  esac
}

