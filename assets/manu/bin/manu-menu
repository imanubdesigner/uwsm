  case $(menu "Install" "󰫏  Ruby on Rails\n  Docker DB\n  JavaScript\n  Go\n  PHP\n  Python\n  Elixir\n  Zig\n  Rust\n  Java\n  .NET\n  OCaml\n  Clojure\n  Scala") in
  *Rails*) present_terminal "manu-install-dev-env ruby" ;;
  *Docker*) present_terminal manu-install-docker-dbs ;;
  *JavaScript*) show_install_javascript_menu ;;
  *Go*) present_terminal "manu-install-dev-env go" ;;
  *PHP*) show_install_php_menu ;;
  *Python*) present_terminal "manu-install-dev-env python" ;;
  *Elixir*) show_install_elixir_menu ;;
  *Zig*) present_terminal "manu-install-dev-env zig" ;;
  *Rust*) present_terminal "manu-install-dev-env rust" ;;
  *Java*) present_terminal "manu-install-dev-env java" ;;
  *NET*) present_terminal "manu-install-dev-env dotnet" ;;
  *OCaml*) present_terminal "manu-install-dev-env ocaml" ;;
  *Clojure*) present_terminal "manu-install-dev-env clojure" ;;
  *Scala*) present_terminal "manu-install-dev-env scala" ;;
  *) show_install_menu ;;
  esac
}

