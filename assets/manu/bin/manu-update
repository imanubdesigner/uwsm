#!/bin/bash

#    ┳┳┏┓┳┓┏┓┏┳┓┏┓
#    ┃┃┃┃┃┃┣┫ ┃ ┣
#    ┗┛┣┛┻┛┛┗ ┻ ┗┛
#

set -e

# ────────────────────────────────────────────────
#  Log capture (PTY mode for animations)
# ────────────────────────────────────────────────
if [[ -z $MANU_UPDATE_LOGGED ]]; then
  script_command=$(printf '%q ' "$0" "$@")
  exec env MANU_UPDATE_LOGGED=1 script -qefc "$script_command" "/tmp/manu-update.log"
fi

trap 'echo ""; echo -e "\033[0;31m󰅚 Something went wrong during the update!\n\nPlease review the output above carefully and correct the error.\033[0m"' ERR

# ────────────────────────────────────────────────
#  Terminal Check
# ────────────────────────────────────────────────
if [ ! -t 1 ]; then
  exec uwsm-app -- xdg-terminal-exec --class=org.manu.terminal -e bash "$0" "$@"
fi

# ────────────────────────────────────────────────
#  Run
# ────────────────────────────────────────────────
if [[ $1 == "-y" ]] || manu-update-confirm; then
  manu-update-snapshot
  manu-update-perform
fi
