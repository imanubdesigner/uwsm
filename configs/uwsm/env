# Changes require a restart to take effect.

# Ensure Manu bins are in the path
export MANU_PATH=$HOME/.local/share/manu
export PATH=$MANU_PATH/bin:$PATH:$HOME/.local/bin

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
manu-cmd-present mise && eval "$(mise activate bash --shims)"
